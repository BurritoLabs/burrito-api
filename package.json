{
  "name": "burrito-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed:sample": "tsx src/scripts/seedSample.ts",
    "import:trades": "tsx src/scripts/importTrades.ts",
    "aggregate:candles": "tsx src/scripts/aggregateCandles.ts",
    "resolve:start-heights": "tsx src/scripts/resolveStartHeights.ts",
    "validate:config": "tsx src/scripts/validateConfig.ts",
    "test:rpc-parser": "tsx src/scripts/testRpcParser.ts",
    "worker": "tsx src/workers/realtimeWorker.ts",
    "worker:realtime": "tsx src/workers/realtimeWorker.ts",
    "worker:backfill": "tsx src/workers/backfillWorker.ts",
    "test:candles": "tsx src/scripts/testCandles.ts",
    "test": "npm run build && npm run test:candles && npm run test:rpc-parser && npm run validate:config"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "better-sqlite3": "^12.10.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
